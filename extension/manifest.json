{
  "manifest_version": 3,
  "name": "Customer Review Sentiment Analyzer",
  "version": "0.2.0",
  "description": "Analyze visible customer reviews and chat with them using session-based RAG.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Review RAG Assistant"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ]
}